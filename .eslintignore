# Compiled output from the TS migration (generated by `npm run build:cjs`).
# Strategy: glob each directory under CJS->TS conversion so a freshly-compiled
# `.js` from a new `.ts` never bombs the static-analysis gate, but re-include
# (`!`) the still-hand-written `.js` so genuine source is still linted.
#
# Per conversion: when you convert `<dir>/X.js` -> `<dir>/X.ts`, DELETE its
# `!<dir>/X.js` line below (its compiled output must now be ignored, not linted).
lib/core/*.js
!lib/core/nels.js
!lib/core/subagent-limit.js
lib/agents/*.js
lib/tools/*.js
lib/review/*.js
lib/commands/*.js
