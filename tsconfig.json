{
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2024",
    "resolveJsonModule": true
  },
  "include": [
    "index.ts",
    "px.ts",
    "lib/**/*.ts"
  ],
  "exclude": [
    "test/",
    "graphify-out/",
    ".forgejo-local/",
    "dist/"
  ]
}
